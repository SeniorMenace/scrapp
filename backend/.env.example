# Application
PORT=4000
NODE_ENV=development

# Cache (seconds)
CACHE_TTL=300

# Rate limiting (requests per minute per IP)
RATE_LIMIT=10

# Request timeout per scraper (milliseconds)
REQUEST_TIMEOUT=8000

# Logging level: error | warn | log | debug
LOG_LEVEL=log

# CORS - comma-separated origins, or * for all
CORS_ORIGIN=*

# Optional: HTTP proxy for scraping (e.g. http://user:pass@proxy.host:port)
PROXY_URL=

# Optional: PostgreSQL for price history (V2 feature)
# DATABASE_URL=postgresql://user:password@localhost:5432/scraper
